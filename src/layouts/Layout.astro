---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Bharath Rajiv Nair - Robotics Software Engineer specializing in 3D Perception, Sensor Fusion, and Robotics AI" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script is:inline>
      const saved = localStorage.getItem('theme');
      const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', saved || preferred);
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --font-sans: 'Inter', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    --max-width: 900px;
  }

  [data-theme="dark"] {
    --color-bg: #0a0a0a;
    --color-surface: #1c1c1c;
    --color-surface-hover: #2a2a2a;
    --color-surface-2: #252525;
    --color-border: #333;
    --color-text: #e5e5e5;
    --color-text-muted: #999;
    --color-accent: #3b82f6;
    --color-accent-dim: #1d4ed8;
    --color-accent-glow: rgba(59, 130, 246, 0.15);
    --color-nav-bg: rgba(10, 10, 10, 0.8);
    --color-green: #34d399;
    --color-green-dim: rgba(52, 211, 153, 0.12);
    --color-purple: #a78bfa;
    --color-purple-dim: rgba(167, 139, 250, 0.12);
    --color-amber: #fbbf24;
    --color-amber-dim: rgba(251, 191, 36, 0.12);
    --color-rose: #fb7185;
    --color-rose-dim: rgba(251, 113, 133, 0.12);
    --color-cyan: #22d3ee;
    --color-cyan-dim: rgba(34, 211, 238, 0.12);
  }

  [data-theme="light"] {
    --color-bg: #e8f0fe;
    --color-surface: #f0f6ff;
    --color-surface-hover: #dce8fc;
    --color-surface-2: #d4e0f5;
    --color-border: #b8cce8;
    --color-nav-bg: rgba(232, 240, 254, 0.85);
    --color-text: #1a1a1a;
    --color-text-muted: #666;
    --color-accent: #2563eb;
    --color-accent-dim: #1d4ed8;
    --color-accent-glow: rgba(37, 99, 235, 0.1);
    --color-green: #059669;
    --color-green-dim: rgba(5, 150, 105, 0.08);
    --color-purple: #7c3aed;
    --color-purple-dim: rgba(124, 58, 237, 0.08);
    --color-amber: #d97706;
    --color-amber-dim: rgba(217, 119, 6, 0.08);
    --color-rose: #e11d48;
    --color-rose-dim: rgba(225, 29, 72, 0.08);
    --color-cyan: #0891b2;
    --color-cyan-dim: rgba(8, 145, 178, 0.08);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    transition: background 0.3s, color 0.3s;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: #60a5fa;
  }

  [data-theme="light"] a:hover {
    color: #1d4ed8;
  }

  ::selection {
    background: var(--color-accent);
    color: white;
  }

  .section-title::after {
    background: linear-gradient(90deg, var(--color-accent), var(--color-purple), var(--color-green)) !important;
    width: 60px !important;
  }
</style>
