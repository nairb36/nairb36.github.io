---
const projects = [
  {
    title: 'Modular 3D Multi-Object Tracking Framework',
    description: 'Plugin-based MOT framework in C++ with interchangeable detection, motion-model, and association modules. Features ONNX Runtime inference for PointPillars, CTRV-UKF state estimation, and Mahalanobis-gated Hungarian matching.',
    tags: ['C++', 'ONNX Runtime', '3D Detection', 'UKF', 'Hungarian Matching', 'Modular Architecture'],
    github: 'https://github.com/nairb36',
    gif: '/projects/mot.gif',
  },
  {
    title: 'SensorLens',
    description: 'An IDE for your tracker — interactive 3D visualization and debugging tool for multi-object tracking on autonomous driving datasets. Step through frames, inspect every bounding box, and see exactly where your tracker fails (ID switches, false positives, missed detections) with color-coded MOT diagnostics. Supports nuScenes, KITTI, Waymo, and Argoverse 2 through a universal dataset-agnostic scene format.',
    tags: ['Python', 'Visual Debugging', 'MOT Evaluation', 'Multi-Dataset', 'Universal Format', '3D Visualization'],
    github: 'https://github.com/nairb36',
    gif: '/projects/sensorlens.gif',
  },
  {
    title: 'Kalman & Particle Filters',
    description: 'Implemented KF, UKF, and Particle Filter algorithms for localization and multi-sensor tracking using LiDAR and radar measurements.',
    tags: ['C++', 'Python', 'State Estimation', 'Sensor Fusion'],
    github: 'https://github.com/nairb36',
    gif: '',
  },
  {
    title: 'Vision Transformer (ViT) & DeiT',
    description: 'Implemented Vision Transformer and Data-efficient Image Transformer from scratch in PyTorch, including patch embeddings, multi-head self-attention, and knowledge distillation.',
    tags: ['PyTorch', 'Transformers', 'Computer Vision'],
    github: 'https://github.com/nairb36',
    gif: '',
  },
  {
    title: 'CLIP-style Vision-Language Model',
    description: 'Built a CLIP-style VLM in PyTorch using contrastive learning to align image and text embeddings on a custom image-caption dataset.',
    tags: ['PyTorch', 'VLM', 'Contrastive Learning'],
    github: 'https://github.com/nairb36',
    gif: '',
  },
];
---

<section id="projects" class="section">
  <h2 class="section-title">Projects</h2>
  <div class="projects-grid">
    {projects.map((project) => (
      <div class:list={['project-card', { 'has-gif': project.gif }]}>
        {project.gif && (
          <div class="project-gif" data-gif={project.gif}>
            <img src={project.gif} alt={`${project.title} demo`} loading="lazy" />
            <div class="gif-expand-hint">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
            </div>
          </div>
        )}
        <div class="project-body">
          <div class="project-top">
            <svg class="folder-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
            </svg>
            <a href={project.github} target="_blank" rel="noopener noreferrer" class="github-link" aria-label="GitHub">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
              </svg>
            </a>
          </div>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="tags">
            {project.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Lightbox overlay -->
<div id="gif-lightbox" class="lightbox">
  <img id="lightbox-img" src="" alt="Enlarged demo" />
</div>

<script>
  // Lightbox open
  document.querySelectorAll('.project-gif').forEach(el => {
    el.addEventListener('click', () => {
      const src = el.getAttribute('data-gif');
      const lightbox = document.getElementById('gif-lightbox');
      const img = document.getElementById('lightbox-img') as HTMLImageElement;
      if (lightbox && img && src) {
        img.src = src;
        lightbox.classList.add('active');
      }
    });
  });

  // Lightbox close
  document.getElementById('gif-lightbox')?.addEventListener('click', (e) => {
    const lightbox = document.getElementById('gif-lightbox');
    lightbox?.classList.remove('active');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.getElementById('gif-lightbox')?.classList.remove('active');
    }
  });
</script>

<style>
  .section {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 6rem 2rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 2.5rem;
    letter-spacing: -0.02em;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: var(--color-accent);
    margin-top: 0.5rem;
    border-radius: 2px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-border);
    border-radius: 8px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    transition: all 0.3s;
  }

  .project-card:hover {
    border-color: var(--color-green);
    border-top-color: var(--color-green);
    background: var(--color-surface-hover);
    transform: translateY(-2px);
  }

  .project-card:hover h3 {
    color: var(--color-green);
  }

  .project-card:hover p {
    color: var(--color-text);
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .folder-icon {
    color: var(--color-accent);
  }

  .github-link {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .github-link:hover {
    color: var(--color-text);
  }

  h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.7;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tags span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-green);
    background: var(--color-green-dim);
    border: 1px solid var(--color-green);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    transition: all 0.2s;
  }

  .tags span:hover {
    background: var(--color-green);
    color: var(--color-bg);
  }

  /* Cards with GIFs */
  .has-gif {
    grid-column: 1 / -1;
    flex-direction: row;
    padding: 0;
    overflow: hidden;
  }

  .project-gif {
    flex-shrink: 0;
    width: 360px;
    position: relative;
    cursor: pointer;
    overflow: hidden;
  }

  .project-gif img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    background: #000;
  }

  .gif-expand-hint {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background: rgba(0, 0, 0, 0.6);
    color: white;
    border-radius: 4px;
    padding: 4px 6px;
    display: flex;
    align-items: center;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .project-gif:hover .gif-expand-hint {
    opacity: 1;
  }

  .has-gif .project-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
  }

  .lightbox.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  @media (max-width: 768px) {
    .has-gif {
      flex-direction: column;
    }
    .project-gif {
      width: 100%;
      max-height: 240px;
    }
  }
</style>
