---
const items = [
  {
    label: 'Georgia Tech',
    role: 'M.S. in Computer Science (AI)',
    period: '2026 - Present',
    type: 'education',
    flag: '🇺🇸',
    months: 6,
  },
  {
    label: 'ArcBest Technologies',
    role: 'Robotics Software Engineer, Perception',
    period: 'Jul 2022 - Present',
    type: 'work',
    flag: '🇺🇸',
    months: 48,
  },
  {
    label: 'Columbia University',
    role: 'M.S. in Mechanical Engineering',
    period: '2020 - 2022',
    type: 'education',
    flag: '🇺🇸',
    months: 21,
  },
  {
    label: 'Amazon Robotics',
    role: 'Applied Scientist Intern',
    period: 'May - Aug 2021',
    type: 'work',
    flag: '🇺🇸',
    months: 3,
  },
  {
    label: 'SUTD',
    role: 'Research Assistant, ROAR Lab',
    period: 'Aug 2019 - Jun 2020',
    type: 'work',
    flag: '🇸🇬',
    months: 10,
  },
  {
    label: 'Purdue University',
    role: 'Visiting Research Student',
    period: 'Jan - May 2019',
    type: 'work',
    flag: '🇺🇸',
    months: 5,
  },
  {
    label: 'BITS Pilani',
    role: 'B.E. (Hons.) in Mechanical Engineering',
    period: '2015 - 2019',
    type: 'education',
    flag: '🇮🇳',
    months: 48,
  },
];

// Scale: 2px per month, min 80px
const heights = items.map(it => Math.max(80, it.months * 2.5));
---

<section id="timeline" class="section">
  <h2 class="section-title">Journey</h2>
  <div class="tl-legend">
    <span class="legend-item legend-edu"><span class="legend-dot"></span> Education</span>
    <span class="legend-item legend-work"><span class="legend-dot"></span> Work</span>
  </div>
  <div class="timeline">
    <div class="timeline-line"></div>
    {items.map((item, i) => (
      <div class:list={['tl-row', item.type === 'education' ? 'tl-left' : 'tl-right']}>
        <div class:list={['tl-col', 'tl-col-left', item.type === 'education' ? 'tl-active' : 'tl-empty']}>
          <div class:list={['tl-card', item.type]} style={`min-height: ${heights[i]}px;`}>
            <span class="tl-period">{item.period}</span>
            <h3>{item.label} <span class="tl-flag">{item.flag}</span></h3>
            <p class="tl-role">{item.role}</p>
          </div>
        </div>
        <div class:list={['tl-dot', item.type]}>
          {item.type === 'education' ? (
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/></svg>
          ) : (
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v3"/></svg>
          )}
        </div>
        <div class:list={['tl-col', 'tl-col-right', item.type === 'work' ? 'tl-active' : 'tl-empty']}>
          <div class:list={['tl-card', item.type]} style={`min-height: ${heights[i]}px;`}>
            <span class="tl-period">{item.period}</span>
            <h3>{item.label} <span class="tl-flag">{item.flag}</span></h3>
            <p class="tl-role">{item.role}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .section {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 6rem 2rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: var(--color-accent);
    margin-top: 0.5rem;
    border-radius: 2px;
  }

  .tl-legend {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .legend-edu .legend-dot { background: var(--color-purple); }
  .legend-work .legend-dot { background: var(--color-green); }

  .timeline {
    position: relative;
  }

  .timeline-line {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--color-accent), var(--color-purple), var(--color-green), var(--color-amber), var(--color-cyan));
    border-radius: 1px;
  }

  .tl-row {
    display: flex;
    align-items: stretch;
    margin-bottom: 1.25rem;
  }

  .tl-row:last-child {
    margin-bottom: 0;
  }

  .tl-col {
    flex: 1;
    min-width: 0;
  }

  .tl-col-left {
    padding-right: 1.75rem;
    display: flex;
    justify-content: flex-end;
  }

  .tl-col-right {
    padding-left: 1.75rem;
    display: flex;
    justify-content: flex-start;
  }

  .tl-col .tl-card {
    width: 100%;
  }

  .tl-empty .tl-card {
    visibility: hidden;
  }

  .tl-col-left.tl-active .tl-card {
    text-align: right;
  }

  .tl-dot {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 1;
    align-self: center;
  }

  .tl-dot.education {
    background: var(--color-bg);
    box-shadow: inset 0 0 0 100px var(--color-purple-dim);
    color: var(--color-purple);
    border: 2px solid var(--color-purple);
  }

  .tl-dot.work {
    background: var(--color-bg);
    box-shadow: inset 0 0 0 100px var(--color-green-dim);
    color: var(--color-green);
    border: 2px solid var(--color-green);
  }

  .tl-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .tl-card.education {
    background: var(--color-purple-dim);
  }

  .tl-card.work {
    background: var(--color-green-dim);
  }

  .tl-card.education:hover {
    border-color: var(--color-purple);
    background: var(--color-surface-hover);
  }

  .tl-card.work:hover {
    border-color: var(--color-green);
    background: var(--color-surface-hover);
  }

  .tl-card.education:hover h3 { color: var(--color-purple); }
  .tl-card.work:hover h3 { color: var(--color-green); }

  .tl-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .tl-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 0.25rem;
    transition: color 0.2s;
  }

  .tl-flag {
    font-size: 0.8rem;
  }

  .tl-role {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-top: 0.15rem;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .timeline-line {
      left: 15px;
      transform: none;
    }

    .tl-col-left {
      display: none;
    }

    .tl-col-right {
      padding-left: 1.25rem;
    }

    .tl-col-right.tl-empty .tl-card {
      visibility: visible;
    }

    .tl-card {
      min-height: auto !important;
      text-align: left !important;
    }
  }
</style>
