---
const publications = [
  {
    title: 'Embedded neuromorphic architecture for form+function 4D printing of robotic materials',
    venue: 'IEEE ICRA 2021',
    authors: ['S. Eom', 'P. Abbaraju', 'Y. Xu', '**B. R. Nair**', 'R. M. Voyles'],
  },
  {
    title: 'Towards staircase navigation and maintenance using self-reconfigurable service robot',
    venue: 'Expert Systems with Applications, 2025',
    authors: ['A. V. Le', 'T. L. A. Pamela', 'A. A. Hayat', '**B. R. Nair**', 'et al.'],
  },
  {
    title: 'Collaborative perception in multi-robot systems: case studies in household cleaning and warehouse operations',
    venue: 'ICRCV 2024',
    authors: ['**B. R. Nair**'],
  },
  {
    title: 'Advancing robotic surgery: affordable kinesthetic and tactile feedback solutions for endotrainers',
    venue: 'CCRIS 2024',
    authors: ['**B. R. Nair**', 'T. Aravinthkumar', 'B. Vinod'],
  },
  {
    title: 'A modular and autonomous staircase-climbing robot with mopping module',
    venue: 'Technical Disclosure, SUTD, 2020',
    authors: ['M. R. Elara', 'T. L. A. Pamela', '**B. R. Nair**', 'et al.'],
  },
];
---

<section id="publications" class="section">
  <h2 class="section-title">Publications</h2>
  <div class="pub-list">
    {publications.map((pub) => (
      <div class="pub-item">
        <h3>{pub.title}</h3>
        <p class="authors">{pub.authors.map((a, i) => (
          <>
            {a.startsWith('**') ? <strong>{a.replace(/\*\*/g, '')}</strong> : a}
            {i < pub.authors.length - 1 ? ', ' : ''}
          </>
        ))}</p>
        <span class="venue">{pub.venue}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .section {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 6rem 2rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 2.5rem;
    letter-spacing: -0.02em;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: var(--color-accent);
    margin-top: 0.5rem;
    border-radius: 2px;
  }

  .pub-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .pub-item {
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--color-border);
    border-radius: 0 6px 6px 0;
    transition: all 0.3s;
  }

  .pub-item:hover {
    border-color: var(--color-cyan);
    background: var(--color-surface-hover);
  }

  .pub-item:hover h3 {
    color: var(--color-cyan);
  }

  h3 {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .authors {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 0.25rem;
  }

  .venue {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-cyan);
  }

  .authors strong {
    color: var(--color-text);
  }
</style>
