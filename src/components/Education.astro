---
const education = [
  {
    school: 'Georgia Institute of Technology',
    degree: 'M.S. in Computer Science',
    specialization: 'Artificial Intelligence specialization',
    location: 'Atlanta, GA 🇺🇸',
    period: 'In Progress (Part-time)',
    logo: '/logos/gatech.jpg',
  },
  {
    school: 'Columbia University',
    degree: 'M.S. in Mechanical Engineering',
    specialization: 'Robotics and Control specialization',
    location: 'New York, NY 🇺🇸',
    period: '2022',
    logo: '/logos/columbia.jpg',
  },
  {
    school: 'BITS Pilani',
    degree: 'B.E. (Hons.) in Mechanical Engineering',
    specialization: '',
    location: 'Pilani, India 🇮🇳',
    period: '2019',
    logo: '/logos/bits.jpg',
  },
];
---

<section id="education" class="section">
  <h2 class="section-title">Education</h2>
  <div class="edu-list">
    {education.map((edu) => (
      <div class="edu-item">
        <img src={edu.logo} alt={edu.school} class="edu-logo" width="80" height="80" />
        <div class="edu-info">
          <div class="edu-header">
            <div>
              <h3>{edu.school}</h3>
              <p class="degree">{edu.degree}</p>
              {edu.specialization && <p class="specialization">{edu.specialization}</p>}
            </div>
            <div class="meta">
              <span class="period">{edu.period}</span>
              <span class="location">{edu.location}</span>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .section {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 6rem 2rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 2.5rem;
    letter-spacing: -0.02em;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: var(--color-accent);
    margin-top: 0.5rem;
    border-radius: 2px;
  }

  .edu-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .edu-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem 1.75rem;
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    transition: all 0.3s;
  }

  .edu-item:hover {
    border-color: var(--color-purple);
    border-left-color: var(--color-purple);
    background: var(--color-surface-hover);
  }

  .edu-item:hover h3 {
    color: var(--color-purple);
  }

  .edu-logo {
    border-radius: 10px;
    flex-shrink: 0;
    margin-top: 2px;
    object-fit: cover;
    border: 1px solid var(--color-border);
  }

  .edu-info {
    flex: 1;
    min-width: 0;
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .degree {
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-top: 0.2rem;
  }

  .specialization {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-top: 0.15rem;
    font-style: italic;
  }

  .meta {
    text-align: right;
    flex-shrink: 0;
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    display: block;
  }

  .location {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .edu-header {
      flex-direction: column;
    }
    .meta {
      text-align: left;
    }
  }
</style>
