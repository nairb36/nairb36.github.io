<section class="hero">
  <div class="hero-content">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="greeting">Hi, I'm</p>
        <h1>Bharath Rajiv Nair</h1>
        <h2><span id="rotating-title"></span></h2>
        <p class="tagline">
          Building real-time perception systems for autonomous robots.
          Specializing in 3D perception, sensor fusion, and multi-object tracking.
        </p>
        <div class="cta">
          <a href="#projects" class="btn btn-primary">View Projects</a>
          <a href="#contact" class="btn btn-secondary">Get in Touch</a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/profile.jpeg" alt="Bharath Rajiv Nair" width="280" height="280" />
      </div>
    </div>
  </div>
</section>

<script>
  const titles = [
    'Robotics Software Engineer',
    'Perception Engineer',
    'Research Engineer',
    'Robotics AI Engineer',
  ];
  let index = 0;
  const el = document.getElementById('rotating-title');
  if (el) {
    el.textContent = titles[0];

    async function typeTitle(text: string) {
      // Delete current text
      const current = el!.textContent || '';
      for (let i = current.length; i >= 0; i--) {
        el!.textContent = current.slice(0, i);
        await new Promise(r => setTimeout(r, 40));
      }
      // Type new text
      for (let i = 0; i <= text.length; i++) {
        el!.textContent = text.slice(0, i);
        await new Promise(r => setTimeout(r, 60));
      }
    }

    setInterval(async () => {
      index = (index + 1) % titles.length;
      await typeTitle(titles[index]);
    }, 3000);
  }
</script>

