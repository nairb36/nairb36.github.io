---
const experiences = [
  {
    company: 'ArcBest Technologies',
    role: 'Robotics Software Engineer, Perception',
    location: 'Fort Smith, AR',
    period: 'Jul 2022 - Present',
    logo: '/logos/arcbest.svg',
    highlights: [
      'Designed and deployed a real-time 3D collision avoidance system in C++/ROS using multi-LiDAR fusion, achieving >98% success rate in dynamic warehouse environments.',
      'Architected a modular, configuration-driven multi-modal sensor calibration framework (camera-camera, camera-LiDAR, LiDAR-LiDAR), enabling fully remote calibration by teleoperators.',
      'Enhanced a low-latency teleoperation pipeline with YOLOv8-based barcode detection for semi-autonomous scanning, improving operator efficiency by 17%.',
      'Built a real-time LiDAR Bird\'s-Eye View (BEV) visualization system with dynamic ROI filtering for improved spatial awareness during teleoperation.',
      'Integrated multi-modal perception sensors on NVIDIA Jetson Orin, building real-time perception pipelines using ROS and PCL.',
      'Deployed robotic systems at the first two customer sites, ensuring reliable perception system performance.',
    ],
  },
  {
    company: 'Amazon Robotics',
    role: 'Applied Scientist Intern',
    location: 'North Reading, MA',
    period: 'May 2021 - Aug 2021',
    logo: '/logos/amazon.svg',
    highlights: [
      'Developed a proof-of-concept simulation for realistic multi-agent warehouse motion (workers, pallet jacks, forklifts), enabling scalable layout optimization and robot throughput analysis.',
      'Implemented multi-agent path planning, trajectory execution, and dynamic obstacle avoidance in Python.',
    ],
  },
  {
    company: 'Purdue University',
    role: 'Visiting Undergraduate Researcher',
    location: 'West Lafayette, IN',
    period: 'Jan 2019 - May 2019',
    logo: '/logos/purdue.svg',
    highlights: [
      'Developed a neuromorphic neural network for tactile robotic skin in Python/Keras, optimizing printable, hardware-constrained analog designs; presented at ICRA 2021.',
    ],
  },
];
---

<section id="experience" class="section">
  <h2 class="section-title">Experience</h2>
  <div class="timeline">
    {experiences.map((exp) => (
      <div class="timeline-item">
        <div class="timeline-header">
          <div class="header-left">
            <img src={exp.logo} alt={exp.company} class="company-logo" width="44" height="44" />
            <div>
              <h3>{exp.company}</h3>
              <p class="role">{exp.role}</p>
            </div>
          </div>
          <div class="meta">
            <span class="period">{exp.period}</span>
            <span class="location">{exp.location}</span>
          </div>
        </div>
        <ul>
          {exp.highlights.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
  .section {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 6rem 2rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 2.5rem;
    letter-spacing: -0.02em;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: var(--color-accent);
    margin-top: 0.5rem;
    border-radius: 2px;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-border);
    border-radius: 8px;
    padding: 1.75rem;
    transition: all 0.3s;
  }

  .timeline-item:hover {
    border-color: var(--color-accent-dim);
    border-left-color: var(--color-accent);
    background: var(--color-surface-hover);
  }

  .timeline-item:hover h3 {
    color: var(--color-accent);
  }

  .timeline-item:hover li {
    color: var(--color-text);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.25rem;
    gap: 1rem;
  }

  .header-left {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .company-logo {
    border-radius: 8px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  h3 {
    font-size: 1.15rem;
    font-weight: 600;
  }

  .role {
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .meta {
    text-align: right;
    flex-shrink: 0;
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    display: block;
  }

  .location {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  li {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    padding-left: 1rem;
    position: relative;
  }

  li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 4px;
    height: 4px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  @media (max-width: 640px) {
    .timeline-header {
      flex-direction: column;
    }
    .meta {
      text-align: left;
    }
  }
</style>
